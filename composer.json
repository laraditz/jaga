{
    "name": "laraditz/jaga",
    "description": "Route-based RBAC for Laravel with auto-synced permissions and wildcard support",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Laraditz\\Jaga\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laraditz\\Jaga\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": ["Laraditz\\Jaga\\JagaServiceProvider"],
            "aliases": { "Jaga": "Laraditz\\Jaga\\Facades\\Jaga" }
        }
    },
    "config": {
        "allow-plugins": { "pestphp/pest-plugin": true }
    }
}
